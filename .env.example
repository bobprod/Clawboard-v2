# ─── Clawboard — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Security ─────────────────────────────────────────────────────────────────
# Bearer token for API authentication. Leave empty for unauthenticated dev mode.
CLAWBOARD_SECRET=

# AES-256-GCM key (64 hex chars) for encrypting API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLAWBOARD_KEK=

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://clawboard:clawboard@localhost:5432/clawboard

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LLM API Keys (optional — can also be set via Settings > API Keys in the UI)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
GEMINI_API_KEY=

# ─── Ollama (local models) ────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Optional: auth token injected at build time (CI/CD)
VITE_AUTH_TOKEN=
